# ---- Этап сборки (build) ----
# Используем официальный образ Maven с JDK 21 для компиляции
FROM maven:3.8.4-openjdk-17-slim AS build

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем только POM-файл, чтобы скачать зависимости отдельно от исходников
# Это позволяет использовать докер-кэш: зависимости не будут перекачиваться при каждом изменении кода
COPY pom.xml .
RUN mvn dependency:go-offline

# Теперь копируем весь исходный код и собираем приложение
COPY src ./src
# Сборка с пропуском тестов (для ускорения, но при желании можно убрать -DskipTests)
RUN mvn clean package -DskipTests

# ---- Финальный этап (runtime) ----
# Используем легковесный образ с JRE (без JDK)
FROM eclipse-temurin:21-jre-alpine

# Устанавливаем рабочую директорию
WORKDIR /app

# Копируем собранный JAR-файл из первого этапа
COPY --from=build /app/target/*.jar app.jar

# Указываем порт, который будет слушать приложение
EXPOSE 8088

# Команда для запуска приложения
ENTRYPOINT ["java", "-jar", "app.jar"]